---
import '../styles/global.css';
import SearchBox from '../components/islands/SearchBox';
import ThemeToggle from '../components/islands/ThemeToggle';
import { SITE } from '../lib/site';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  pagefind?: boolean;
}

const {
  title,
  description = SITE.description,
  image = SITE.ogImage,
  type = 'website',
  pagefind = true,
} = Astro.props;
const pageTitle = title === SITE.title ? SITE.title : `${title} | ${SITE.title}`;
const canonicalUrl = new URL(Astro.url.pathname, SITE.url).toString();
const imageUrl = new URL(image, SITE.url).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.title} RSS`} href={SITE.rss} />
    <link rel="sitemap" href={SITE.sitemap} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        const key = 'theme';
        const root = document.documentElement;
        const saved = localStorage.getItem(key);
        const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved === 'light' || saved === 'dark' ? saved : (systemPrefersDark ? 'dark' : 'light');
        root.classList.toggle('dark', theme === 'dark');
      })();
    </script>
  </head>
  <body class="grain min-h-screen bg-paper text-ink transition-colors duration-300 ease-out dark:bg-night dark:text-night-text">
    <header class="sticky top-0 z-20 border-b border-ink-faint bg-paper/90 backdrop-blur-sm transition-colors duration-300 dark:border-night-border dark:bg-night/90">
      <div class="mx-auto flex h-14 max-w-[720px] items-center justify-between px-8">
        <a href="/" class="fvar-h3 font-fraunces text-[15px] font-medium tracking-tight text-ink dark:text-night-text">afourblog</a>
        <div class="flex items-center gap-4">
          <nav class="hidden items-center gap-3 sm:flex">
            <a href="/archive" class="font-news text-[15px] text-ink-muted transition-colors duration-150 ease-out hover:text-accent dark:text-night-muted">归档</a>
            <a href="/categories" class="font-news text-[15px] text-ink-muted transition-colors duration-150 ease-out hover:text-accent dark:text-night-muted">分类</a>
            <a href="/tags" class="font-news text-[15px] text-ink-muted transition-colors duration-150 ease-out hover:text-accent dark:text-night-muted">标签</a>
          </nav>
          <SearchBox client:idle />
          <ThemeToggle client:load />
        </div>
      </div>
    </header>
    <main data-pagefind-body={pagefind} class="mx-auto max-w-[720px] px-8 py-20">
      <slot />
    </main>
  </body>
</html>
