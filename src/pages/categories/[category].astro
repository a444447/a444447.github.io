---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllCategories, getPublishedPosts } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const categories = getAllCategories(posts);
  return categories.map((category) => ({
    params: { category },
    props: {
      category,
      posts: posts.filter((post) => post.data.category === category),
    },
  }));
}

const { category, posts } = Astro.props;
---

<BaseLayout title={`${category} | 分类 | afourblog`}>
  <p class="mb-6 select-none font-mono text-[9.5px] uppercase tracking-[0.16em] text-ink-muted dark:text-night-muted">Category</p>
  <h1 class="fvar-h1 mb-6 font-fraunces text-[60px] font-black leading-[1.2] tracking-tight">{category}</h1>
  <p class="mb-10 font-news text-[18px] leading-[2] text-ink-muted dark:text-night-muted">共 {posts.length} 篇文章</p>
  <div class="space-y-8">
    {posts.map((post) => (
      <article class="group">
        <a href={`/posts/${post.slug}`} class="block">
          <div class="mb-3 flex items-center gap-3">
            <span class="rounded-[5px] border border-accent/30 px-1.5 py-[2px] font-mono text-[9.5px] uppercase leading-none tracking-[0.11em] text-accent">
              {post.data.category}
            </span>
            <time class="font-news text-sm text-ink-muted dark:text-night-muted" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })}
            </time>
          </div>
          <h2 class="fvar-h3 mb-2 font-fraunces text-[26px] leading-[1.38] text-ink transition-colors duration-150 ease-out group-hover:text-accent dark:text-night-text">
            {post.data.title}
          </h2>
          <p class="font-news text-[16.5px] leading-relaxed text-ink-muted dark:text-night-muted">{post.data.description}</p>
        </a>
      </article>
    ))}
  </div>
</BaseLayout>
