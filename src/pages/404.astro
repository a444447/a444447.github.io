---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到" description="这个页面不存在，可能已经移动或删除。" pagefind={false}>
  <section class="py-10">
    <p class="mb-6 select-none font-mono text-[9.5px] uppercase tracking-[0.16em] text-ink-muted dark:text-night-muted">404</p>
    <h1 class="fvar-h1 mb-6 font-fraunces text-[60px] font-black leading-[1.2] tracking-tight">页面未找到</h1>
    <p class="mb-8 font-news text-[18px] leading-[2] text-ink-muted dark:text-night-muted">这个页面不存在，可能已经移动或删除。</p>
    <a
      href="/"
      class="inline-flex rounded-[7px] bg-accent px-5 py-2.5 font-news text-[15px] font-medium text-white transition-all duration-150 ease-out hover:-translate-y-px hover:bg-accent-hover active:translate-y-0"
    >
      返回首页
    </a>
  </section>
</BaseLayout>
